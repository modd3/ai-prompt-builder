# ============================================================================
# Docker Environment Configuration Template
# ============================================================================
# Copy this file to .env and fill in your actual API keys
# This file is used by docker-compose.yml to pass environment variables
# to the backend service
# ============================================================================

# ============================================================================
# AI Model API Keys
# ============================================================================
# Obtain these keys from each provider's dashboard

# OpenAI API Key
# Get it at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Hugging Face API Token
# Get it at: https://huggingface.co/settings/tokens
HUGGINGFACE_TOKEN=your_huggingface_token_here

# Groq API Key (Fastest free inference)
# Get it at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Google Gemini API Key (1M token context)
# Get it at: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Mistral API Key (Concise outputs + vision)
# Get it at: https://console.mistral.ai/api-keys
MISTRAL_API_KEY=your_mistral_api_key_here

# ============================================================================
# Optional: MongoDB Credentials
# ============================================================================
# Uncomment these lines in docker-compose.yml to enable authentication
# MONGO_INITDB_ROOT_USERNAME=admin
# MONGO_INITDB_ROOT_PASSWORD=your_strong_password_here
